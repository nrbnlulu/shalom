/// The GraphQL schema SDL inlined at code-generation time.
///
/// Use this to create the [ShalomRuntimeClient] — no async asset loading needed:
/// ```dart
/// final client = ShalomRuntimeClient.create(schemaSdl: kSchemaSdl, link: link);
/// ```
const String kSchemaSdl = r'''{{ schema_sdl }}''';

/// Register all @Query, @Fragment, @Mutation, and @Subscription operations with the Shalom client.
void registerShalomDefinitions(ShalomRuntimeClient client) {
{% for w in raw_fragments %}  client.registerFragment(document: r'''
{{ w.document }}
''');
{% endfor %}
{% for w in fragments %}  client.registerFragment(document: r'''
fragment {{ w.class_name }} {{ w.document }}
''');
{% endfor %}{% for w in queries %}  client.registerOperation(document: r'''
query {{ w.class_name }} {{ w.document }}
''');
{% endfor %}{% for w in mutations %}  client.registerOperation(document: r'''
mutation {{ w.class_name }} {{ w.document }}
''');
{% endfor %}{% for w in subscriptions %}  client.registerOperation(document: r'''
subscription {{ w.class_name }} {{ w.document }}
''');
{% endfor %}}

